# =========================================================
# AI Agent Project Environment Example
# ---------------------------------------------------------
# 이 파일은 예시 환경변수 파일이다.
# 실제 비밀값은 이 파일에 넣지 않는다.
# 실제 사용 시에는 .env 파일을 별도로 만들고 값을 채운다.
# =========================================================

# ---------------------------------------------------------
# Runtime
# ---------------------------------------------------------
# 사용할 기본 런타임
# 예: python / typescript
AGENT_RUNTIME=python

# 실행 환경
# 예: dev / test / prod
AGENT_ENV=dev

# 로그 레벨
# 예: DEBUG / INFO / WARN / ERROR
AGENT_LOG_LEVEL=INFO

# 오프라인 모드 사용 여부
# 1이면 외부 네트워크 호출 없이 mock/offline 중심으로 동작
# 0이면 실제 외부 연동 가능
AGENT_OFFLINE_MODE=0

# ---------------------------------------------------------
# LiteLLM Gateway
# ---------------------------------------------------------
# LiteLLM Gateway base URL
LITELLM_BASE_URL=http://localhost:4000

# LiteLLM Gateway virtual key 또는 조직 표준 인증 키
# 실제 운영 키는 절대 커밋하지 않는다
LITELLM_VIRTUAL_KEY=sk-REPLACE_ME

# 기본 모델 alias
# 예: gpt-main / reasoning-main / embedding-main
LITELLM_MODEL=gpt-main

# ---------------------------------------------------------
# Agent Common
# ---------------------------------------------------------
# 기본 Agent 이름
AGENT_NAME=SampleAgent

# 요청 타임아웃(밀리초 또는 초는 프로젝트 규칙에 맞게 사용)
# 여기서는 초 단위 예시
AGENT_TIMEOUT_SECONDS=30

# 기본 리트라이 횟수
AGENT_RETRY_COUNT=2

# ---------------------------------------------------------
# Python Runtime
# ---------------------------------------------------------
# FastAPI host
PYTHON_API_HOST=0.0.0.0

# FastAPI port
PYTHON_API_PORT=8000

# Python debug mode
# 1이면 개발 모드, 0이면 일반 모드
PYTHON_DEBUG=1

# ---------------------------------------------------------
# TypeScript Runtime
# ---------------------------------------------------------
# Node.js API host
TS_API_HOST=0.0.0.0

# Node.js API port
TS_API_PORT=3000

# TypeScript/Node 실행 환경
# 예: development / test / production
NODE_ENV=development

# ---------------------------------------------------------
# Observability
# ---------------------------------------------------------
# OpenTelemetry export 사용 여부
OTEL_ENABLED=0

# OpenTelemetry endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# 서비스 이름
OTEL_SERVICE_NAME=ai-agent-service

# ---------------------------------------------------------
# Storage / Cache
# ---------------------------------------------------------
# Redis 사용 여부
REDIS_ENABLED=0

# Redis URL
REDIS_URL=redis://localhost:6379

# PostgreSQL URL
# 필요 시 활성화
DATABASE_URL=postgresql://user:password@localhost:5432/ai_agent

# MongoDB URL
# 필요 시 활성화
MONGODB_URL=mongodb://localhost:27017/ai_agent

# ---------------------------------------------------------
# Files / Object Storage
# ---------------------------------------------------------
# MinIO endpoint
MINIO_ENDPOINT=http://localhost:9000

# MinIO access key
MINIO_ACCESS_KEY=minioadmin

# MinIO secret key
MINIO_SECRET_KEY=minioadmin

# MinIO bucket name
MINIO_BUCKET=ai-agent

# ---------------------------------------------------------
# Security
# ---------------------------------------------------------
# API 인증 토큰 예시
# 실제 값은 비워두거나 secret manager 사용
API_AUTH_TOKEN=REPLACE_ME

# 민감정보 마스킹 활성화 여부
MASK_SENSITIVE_LOGS=1

# ---------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------
# Python runtime 강제 여부
ENABLE_PYTHON_AGENT=1

# TypeScript runtime 강제 여부
ENABLE_TYPESCRIPT_AGENT=1

# Review 단계 자동 실행 여부
ENABLE_AUTO_REVIEW=1

# ---------------------------------------------------------
# Notes
# ---------------------------------------------------------
# 1. 실제 운영 환경에서는 .env.example을 복사해 .env를 만든다.
# 2. 운영 비밀값은 Git 저장소에 커밋하지 않는다.
# 3. 프로젝트에 필요 없는 변수는 제거해도 된다.
# 4. 변수 키 이름을 바꿀 때는 문서와 코드도 함께 갱신한다.
